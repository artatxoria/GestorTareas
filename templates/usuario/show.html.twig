{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - {{ usuario.getNombreCompleto() }}{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto">

    {# Botón de retorno #}
    <div class="mb-3">
        <a href="{{ path('listado_usuarios') }}"
           class="text-gray-400 hover:text-blue-600 transition-colors text-xs flex items-center gap-1.5">
            <i class="bi bi-arrow-left"></i> Volver al listado
        </a>
    </div>

    {# Contenedor principal #}
    <div class="bg-white rounded-2xl p-4 border border-gray-100 shadow-md">

        {# Cabecera con foto #}
        <div class="flex items-center gap-3 mb-4 pb-3 border-b border-gray-100">
            <img src="{{ usuario.fotografia }}"
                 alt="Foto de {{ usuario.getNombreCompleto() }}"
                 class="w-12 h-12 rounded-full object-cover border-2 border-gray-100 flex-shrink-0">
            <div>
                <span class="text-blue-400 text-[10px] font-mono uppercase tracking-widest mb-0.5 block">
                    Referencia #{{ usuario.id }}
                </span>
                <h1 class="text-base font-bold text-gray-800">{{ usuario.getNombreCompleto() }}</h1>
                <p class="text-[10px] text-gray-400">{{ usuario.dni }}</p>
            </div>
        </div>

        {# Cuerpo #}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

            <div class="space-y-1.5">
                <h3 class="text-gray-400 text-[10px] uppercase font-bold tracking-widest mb-1.5">Contacto</h3>
                <div class="bg-gray-50 p-2.5 rounded-lg border border-gray-100 flex justify-between items-center">
                    <span class="text-[10px] text-gray-400">Email</span>
                    <span class="text-[10px] text-gray-700 font-medium truncate ml-2">{{ usuario.email }}</span>
                </div>
                <div class="bg-gray-50 p-2.5 rounded-lg border border-gray-100 flex justify-between items-center">
                    <span class="text-[10px] text-gray-400">Teléfono</span>
                    <span class="text-[10px] text-gray-700 font-medium">{{ usuario.telefono }}</span>
                </div>
            </div>

            <div class="space-y-1.5">
                <h3 class="text-gray-400 text-[10px] uppercase font-bold tracking-widest mb-1.5">Datos personales</h3>
                <div class="bg-gray-50 p-2.5 rounded-lg border border-gray-100 flex justify-between items-center">
                    {# <span class="text-[10px] text-gray-400">Edad</span> 
                    <span class="text-[10px] text-gray-700 font-medium">{{ usuario.edad }} años</span> #}
                </div>
                <div class="bg-gray-50 p-2.5 rounded-lg border border-gray-100 flex justify-between items-center">
                    <span class="text-[10px] text-gray-400">Ciudad</span>
                    <span class="text-[10px] text-gray-700 font-medium">{{ usuario.ciudad }}</span>
                </div>
                <div class="bg-gray-50 p-2.5 rounded-lg border border-gray-100 flex justify-between items-center">
                    <span class="text-[10px] text-gray-400">Comunidad</span>
                    <span class="text-[10px] text-gray-700 font-medium">{{ usuario.comunidad }}</span>
                </div>
            </div>

        </div>

        {# SECCIÓN NUEVA: Tareas asignadas al usuario #}
        <div class="mt-6 pt-4 border-t border-gray-100">
            <h3 class="text-gray-400 text-[10px] uppercase font-bold tracking-widest mb-3">
                Tareas asignadas ({{ tareas|length }})
            </h3>
            
            {% if tareas|length > 0 %}
                <div class="grid grid-cols-1 gap-3">
                    {% for tarea in tareas %}
                        {# Reutilizar el componente de tarjeta de tarea #}
                        {% include 'tarea/_tarea_card.html.twig' with {tarea: tarea} %}
                    {% endfor %}
                </div>
            {% else %}
                <div class="bg-gray-50 p-4 rounded-lg border border-gray-100 text-center">
                    <i class="bi bi-check-circle-fill text-2xl text-green-400 mb-2 block"></i>
                    <p class="text-xs text-gray-500 font-medium">Este usuario no tiene tareas asignadas</p>
                    <p class="text-[10px] text-gray-400 mt-1">¡Todo bajo control!</p>
                </div>
            {% endif %}
        </div>

        {# Acciones #}
        <div class="mt-4 pt-3 border-t border-gray-100">
            <a href="{{ path('listado_usuarios') }}"
               class="bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs px-3 py-1.5 rounded-lg font-bold transition-all">
                ← Volver
            </a>
        </div>

    </div>
</div>
{% endblock %}