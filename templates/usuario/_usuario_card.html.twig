<div class="bg-white rounded-2xl p-6 shadow-md border border-gray-100 hover:border-blue-300 hover:shadow-lg transition-all duration-300 flex flex-col">

    {# Foto y nombre #}
    <div class="flex items-center gap-4 mb-4">
        <img src="{{ usuario.fotografia }}"
             alt="Foto de {{ usuario.getNombreCompleto() }}"
             class="w-16 h-16 rounded-full object-cover border-2 border-gray-100">
        <div>
            <h4 class="text-lg font-bold text-gray-800">{{ usuario.getNombreCompleto() }}</h4>
            <p class="text-xs text-gray-400">{{ usuario.dni }}</p>
        </div>
    </div>

    {# Datos de contacto #}
    <div class="space-y-2 flex-grow mb-6">
        <p class="text-sm text-gray-500">
            <span class="font-semibold text-gray-600">Email:</span>
            {{ usuario.email }}
        </p>
        <p class="text-sm text-gray-500">
            <span class="font-semibold text-gray-600">Teléfono:</span>
            {{ usuario.telefono }}
        </p>
        <p class="text-sm text-gray-500">
            <span class="font-semibold text-gray-600">Ubicación:</span>
            {{ usuario.ciudad }}, {{ usuario.comunidad }}
        </p>
    </div>

    {# Footer: genero + enlace #}
    <div class="flex justify-between items-center pt-4 border-t border-gray-100 mt-auto">
        <div>
            <span class="text-xs text-gray-400 uppercase font-semibold block mb-0.5">Edad</span>
            <span class="font-black text-lg text-blue-600">
                {{ usuario.genero }}<span class="text-gray-300 text-xs font-normal"></span>
            </span>
        </div>
        <a href="{{ path('usuario_show', { id: usuario.id }) }}"
           class="bg-blue-50 hover:bg-blue-100 text-blue-600 font-semibold text-sm px-4 py-2 rounded-xl transition-all">
            Ver &rarr;
        </a>
    </div>

</div>