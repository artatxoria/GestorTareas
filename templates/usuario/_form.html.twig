{# templates/usuario/_form.html.twig #}
<div class="max-w-4xl mx-auto bg-white shadow-lg rounded-xl overflow-hidden border border-gray-100">
    <div class="p-1 bg-gradient-to-r from-blue-500 to-indigo-600"></div> {# Línea decorativa superior #}
    
    {{ form_start(form, {'attr': {'class': 'p-8'}}) }}
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
            
            {# Grupo: Información Personal #}
            <div class="space-y-4">
                <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Datos Personales</h3>
                
                <div>
                    {{ form_label(form.nombre, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.nombre, {'attr': {'class': 'w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm'}}) }}
                    <div class="text-red-500 text-xs mt-1">{{ form_errors(form.nombre) }}</div>
                </div>

                <div>
                    {{ form_label(form.apellido, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.apellido, {'attr': {'class': 'w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm'}}) }}
                    <div class="text-red-500 text-xs mt-1">{{ form_errors(form.apellido) }}</div>
                </div>

                <div>
                    {{ form_label(form.dni, 'DNI / Identificación', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.dni, {'attr': {'class': 'w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm'}}) }}
                </div>
            </div>

            {# Grupo: Contacto y Ubicación #}
            <div class="space-y-4">
                <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Contacto y Ubicación</h3>
                
                <div>
                    {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm'}}) }}
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        {{ form_label(form.ciudad, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.ciudad, {'attr': {'class': 'w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.genero, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.genero, {'attr': {'class': 'w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm'}}) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.fotografia, 'URL de la foto', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.fotografia, {'attr': {'class': 'w-full border-gray-300 rounded-lg shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm', 'placeholder': 'https://...'}} ) }}
                </div>
            </div>
        </div>

        {# Renderiza campos ocultos como el token CSRF y cualquier otro campo restante #}
        {{ form_rest(form) }}

        <div class="mt-10 pt-6 border-t border-gray-100 flex items-center justify-end space-x-4">
            <a href="{{ path('listado_usuarios') }}" class="text-sm font-medium text-gray-500 hover:text-gray-700 transition">
                Cancelar
            </a>
            <button type="submit" class="inline-flex justify-center py-2.5 px-6 border border-transparent shadow-sm text-sm font-semibold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-200">
                <i class="bi bi-save mr-2"></i> {{ button_label|default('Guardar Usuario') }}
            </button>
        </div>

    {{ form_end(form) }}
</div>
