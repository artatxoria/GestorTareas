<div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 hover:border-blue-200 hover:shadow-md transition-all duration-300 flex flex-col">

    {# Estado #}
    <div class="mb-3">
        <span class="inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full {{ tarea.estado.getLabelColor() }}">
            <i class="bi {{ tarea.estado.getIcono() }}"></i>
            {{ tarea.estado.getTextoLegible() }}
        </span>
    </div>

    {# Título #}
    <h4 class="text-sm font-bold text-gray-800 mb-1.5 hover:text-blue-600 transition-colors leading-snug">
        <a href="{{ path('tarea_show', { id: tarea.id }) }}">
            {{ tarea.titulo }}
        </a>
    </h4>

    {# Descripción #}
    <p class="text-gray-400 text-xs leading-relaxed flex-grow mb-4">
        {{ tarea.descripcion|length > 60
            ? tarea.descripcion|slice(0, 60) ~ '...'
            : tarea.descripcion }}
    </p>

    {# Footer #}
    <div class="flex justify-between items-center pt-3 border-t border-gray-100 mt-auto">
        <span class="text-xs font-black {{ tarea.prioridad > 8 ? 'text-red-500' : 'text-blue-500' }}">
            P{{ tarea.prioridad }}<span class="text-gray-300 font-normal">/10</span>
        </span>
        <a href="{{ path('tarea_show', { id: tarea.id }) }}"
           class="text-xs bg-blue-50 hover:bg-blue-100 text-blue-600 font-semibold px-3 py-1.5 rounded-lg transition-all">
            Ver &rarr;
        </a>
    </div>

</div>