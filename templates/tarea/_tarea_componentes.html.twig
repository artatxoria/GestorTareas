{#
    templates/tarea/_tarea_componentes.html.twig
#}
<div class="mt-4 pt-4 border-t border-gray-100">

    {% if tarea.componentes|length > 0 %}

        <h5 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2 flex items-center gap-1">
            <i class="bi bi-tools"></i>
            Componentes ({{ tarea.componentes|length }})
        </h5>

        <ul class="space-y-1">
            {% for componente in tarea.componentes %}
            <li class="flex justify-between items-center text-sm">
                <span class="text-gray-600 truncate mr-2">
                    <i class="bi bi-box text-gray-300 mr-1"></i>
                    {{ componente.nombre }}
                </span>
                {% if componente.coste == 0 %}
                    <span class="text-xs font-medium text-green-500 flex-shrink-0">Gratuito</span>
                {% else %}
                    <span class="text-xs font-medium text-gray-700 flex-shrink-0">
                        {{ (componente.coste / 100)|number_format(2, ',', '.') }} 
                    </span>
                {% endif %}
            </li>
            {% endfor %}
        </ul>

        {% set total = tarea.componentes|reduce((carry, c) => carry + c.coste, 0) %}
        {% if total > 0 %}
        <div class="flex justify-between items-center mt-3 pt-2 border-t border-dashed border-gray-200">
            <span class="text-xs text-gray-400 font-semibold uppercase tracking-wide">Total</span>
            <span class="text-sm font-black text-gray-800">
                {{ (total / 100)|number_format(2, ',', '.') }}
            </span>
        </div>
        {% endif %}

    {% else %}
        <p class="text-xs text-gray-400 italic flex items-center gap-1">
            <i class="bi bi-slash-circle"></i>
            Sin componentes asignados
        </p>
    {% endif %}

</div>