{# templates/tarea/_form.html.twig #}
<div class="max-w-4xl mx-auto bg-white shadow-xl rounded-2xl overflow-hidden border border-gray-100">
    {# Línea decorativa superior en color esmeralda para diferenciarlo de Usuarios #}
    <div class="h-2 bg-gradient-to-r from-emerald-500 to-teal-600"></div>
    
    {{ form_start(form, {'attr': {'class': 'p-8'}}) }}
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6">
            
            {# Columna Izquierda: Identificación de la Tarea #}
            <div class="space-y-5">
                <div class="flex items-center space-x-2 pb-2 border-b border-gray-50">
                    <i class="bi bi-pencil-square text-emerald-600"></i>
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Definición</h3>
                </div>
                
                <div>
                    {{ form_label(form.titulo, 'Título de la Tarea', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.titulo, {'attr': {'class': 'w-full border-gray-200 rounded-xl shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm transition-all', 'placeholder': 'Ej: Revisar inventario...'}}) }}
                    <div class="text-red-500 text-xs mt-1">{{ form_errors(form.titulo) }}</div>
                </div>

                <div>
                    {{ form_label(form.descripcion, 'Descripción', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.descripcion, {'attr': {'class': 'w-full border-gray-200 rounded-xl shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm transition-all', 'rows': '4', 'placeholder': 'Detalles adicionales...'}}) }}
                    <div class="text-red-500 text-xs mt-1">{{ form_errors(form.descripcion) }}</div>
                </div>
            </div>

            {# Columna Derecha: Planificación y Responsable #}
            <div class="space-y-5">
                <div class="flex items-center space-x-2 pb-2 border-b border-gray-50">
                    <i class="bi bi-calendar-event text-emerald-600"></i>
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Planificación</h3>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        {{ form_label(form.estado, 'Estado', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.estado, {'attr': {'class': 'w-full border-gray-200 rounded-xl shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm cursor-pointer'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.prioridad, 'Prioridad (1-10)', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.prioridad, {'attr': {'class': 'w-full border-gray-200 rounded-xl shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm'}}) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.fechaLimite, 'Fecha Límite', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.fechaLimite, {'attr': {'class': 'w-full border-gray-200 rounded-xl shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm'}}) }}
                </div>

                <div>
                    {{ form_label(form.propietario, 'Responsable Asignado', {'label_attr': {'class': 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.propietario, {'attr': {'class': 'w-full border-gray-200 rounded-xl shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm cursor-pointer'}}) }}
                </div>
            </div>
        </div>

        {# Renderiza campos ocultos (token CSRF) #}
        {{ form_rest(form) }}

        {# Acciones del Formulario #}
        <div class="mt-10 pt-6 border-t border-gray-50 flex items-center justify-end space-x-4">
            <a href="{{ path('listado_tareas') }}" class="text-sm font-medium text-gray-400 hover:text-gray-600 transition-colors">
                Cancelar
            </a>
            {# BOTÓN DE GUARDAR CORREGIDO #}
            {# He añadido estilos inline de respaldo por si Tailwind no carga el color de fondo #}
            <button type="submit" class="inline-flex justify-center py-2.5 px-6 border border-transparent shadow-sm text-sm font-semibold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-200">
                <i class="bi bi-save mr-2"></i> {{ button_label|default('Guardar Tarea') }}
            </button>
        </div>

    {{ form_end(form) }}
</div>
