{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - {{ tarea.titulo }}{% endblock %}

{% block body %}
<div class="max-w-md mx-auto">

    {# Botón de retorno #}
    <div class="mb-3">
        <a href="{{ path('listado_tareas') }}"
           class="text-gray-400 hover:text-blue-600 transition-colors text-xs flex items-center gap-1.5">
            <i class="bi bi-arrow-left"></i> Volver al listado
        </a>
    </div>

    {# Contenedor principal #}
    <div class="bg-white rounded-2xl p-4 border border-gray-100 shadow-md">

        {# Cabecera #}
        <div class="flex justify-between items-start gap-3 mb-4 pb-3 border-b border-gray-100">
            <div>
                <span class="text-blue-400 text-[10px] font-mono uppercase tracking-widest mb-0.5 block">
                    Referencia #{{ tarea.id }}
                </span>
                <h1 class="text-base font-bold text-gray-800">{{ tarea.titulo }}</h1>
            </div>
            <div class="flex items-center bg-gray-50 px-3 py-1.5 rounded-lg border border-gray-200 flex-shrink-0">
                {% if tarea.prioridad > 8 %}
                    <i class="bi bi-fire text-base mr-1.5 text-red-500"></i>
                    <span class="text-xs font-black text-red-500">¡URGENTE!</span>
                {% else %}
                    <i class="bi bi-info-circle-fill text-base mr-1.5 text-blue-400"></i>
                    <span class="text-xs font-semibold text-gray-600">P{{ tarea.prioridad }}/10</span>
                {% endif %}
            </div>
        </div>

        {# Cuerpo: una sola columna #}
        <div class="space-y-2">

            <div class="bg-gray-50 p-3 rounded-lg border border-gray-100">
                <span class="text-[10px] text-gray-400 uppercase font-semibold block mb-1">Descripción</span>
                <p class="text-xs text-gray-600 leading-relaxed">{{ tarea.descripcion }}</p>
            </div>

            <div class="bg-gray-50 p-3 rounded-lg border border-gray-100 flex justify-between items-center">
                <span class="text-[10px] text-gray-400 uppercase font-semibold">Estado</span>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider {{ tarea.estado.getLabelColor() }}">
                    <i class="bi {{ tarea.estado.getIcono() }}"></i>
                    {{ tarea.estado.getTextoLegible() }}
                </span>
            </div>

            <div class="bg-gray-50 p-3 rounded-lg border border-gray-100 flex justify-between items-center">
                <span class="text-[10px] text-gray-400 uppercase font-semibold">Fecha límite</span>
                <span class="text-xs font-semibold text-gray-700">{{ tarea.fechaLimite|date('d/m/Y') }}</span>
            </div>

            <div class="bg-gray-50 p-3 rounded-lg border border-gray-100 flex justify-between items-center">
                <span class="text-[10px] text-gray-400 uppercase font-semibold">Tareas similares</span>
                <a href="{{ path('tarea_filtro_estado', { status: tarea.estado.value }) }}"
                   class="text-[10px] text-blue-500 hover:text-blue-700 font-semibold transition-colors">
                    Ver todas →
                </a>
            </div>

        </div>
        
       
        
        
        
        
        
        
        {# Acciones #}
        <div class="mt-4 pt-3 border-t border-gray-100">
            <a href="{{ path('listado_tareas') }}"
               class="bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs px-3 py-1.5 rounded-lg font-bold transition-all">
                ← Volver
            </a>
        </div>

    </div>
</div>
{% endblock %}