{#
    templates/tarea/_tarea_propietario.html.twig
#}
<div class="flex items-center gap-2 mt-3 pt-3 border-t border-gray-100">

    <div class="w-7 h-7 rounded-full bg-blue-100 text-blue-600 flex items-center 
                justify-center text-xs font-bold uppercase flex-shrink-0">
        {{ tarea.propietario.nombre|slice(0, 1) }}
    </div>

    <div class="min-w-0">
        <span class="text-xs text-gray-400 block leading-none mb-0.5">Responsable</span>
        <span class="text-sm font-medium text-gray-700 truncate block">
            {{ tarea.propietario.getNombreCompleto() }}
        </span>
    </div>

    <span class="ml-auto text-xs text-gray-400 flex items-center gap-1 flex-shrink-0">
        <i class="bi bi-geo-alt"></i>
        {{ tarea.propietario.ciudad }}
    </span>
</div>