{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} - Panel Principal{% endblock %}

{% block body %}

    {# Cabecera #}
    <div class="flex justify-between items-center mb-6 pr-4">
        <div>
            <h1 class="text-2xl font-extrabold text-gray-800">Cola de Tareas</h1>
            <p class="text-gray-400 text-sm mt-0.5">
                <span class="text-blue-600 font-semibold">{{ tareas|length }}</span> tareas registradas
            </p>
        </div>
        <a href="{{ path('tarea_new') }}"
           class="bg-blue-600 hover:bg-blue-500 text-white text-sm px-4 py-2 rounded-lg font-bold transition-all shadow hover:-translate-y-0.5">
            + Nueva Tarea
        </a>
    </div>

    {# Rejilla #}
    <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-4">
        {% for tarea in tareas %}
            {{ include('tarea/_tarea_card.html.twig') }}
        {% else %}
            {{ include('tarea/_tarea_vacia.html.twig') }}
        {% endfor %}
    </div>

{% endblock %}