{% extends 'base.html.twig' %}

{% block title %}Componente index{% endblock %}

{% block body %}
    <h1>Componente index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Coste</th>
                <th>Cantidad</th>
                <th>Descripcion</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for componente in componentes %}
            <tr>
                <td>{{ componente.id }}</td>
                <td>{{ componente.nombre }}</td>
                <td>{{ componente.coste }}</td>
                <td>{{ componente.cantidad }}</td>
                <td>{{ componente.descripcion }}</td>
                <td>
                    <a href="{{ path('app_componente_show', {'id': componente.id}) }}">show</a>
                    <a href="{{ path('app_componente_edit', {'id': componente.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_componente_new') }}">Create new</a>
{% endblock %}
