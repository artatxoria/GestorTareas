{% extends 'base.html.twig' %}

{% block title %}Componente{% endblock %}

{% block body %}
    <h1>Componente</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ componente.id }}</td>
            </tr>
            <tr>
                <th>Nombre</th>
                <td>{{ componente.nombre }}</td>
            </tr>
            <tr>
                <th>Coste</th>
                <td>{{ componente.coste }}</td>
            </tr>
            <tr>
                <th>Cantidad</th>
                <td>{{ componente.cantidad }}</td>
            </tr>
            <tr>
                <th>Descripcion</th>
                <td>{{ componente.descripcion }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_componente_index') }}">back to list</a>

    <a href="{{ path('app_componente_edit', {'id': componente.id}) }}">edit</a>

    {{ include('componente/_delete_form.html.twig') }}
{% endblock %}
